rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches request.auth.uid)
    // Fields:
    //   - uid: string (required) - The user's unique ID
    //   - email: string (optional) - The user's email address
    //   - displayName: string (optional) - The user's display name
    //   - cart: list (optional) - The user's shopping cart items
    //   - wishlist: list (optional) - The user's wishlist items
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidUser(data) {
      return data.keys().hasOnly(['uid', 'email', 'displayName', 'cart', 'wishlist']) &&
             data.uid == request.auth.uid &&
             (!('email' in data) || data.email is string) &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('cart' in data) || data.cart is list) &&
             (!('wishlist' in data) || data.wishlist is list);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if false; // Users shouldn't delete their own document directly for now
    }
  }
}
